    {
      "id": "classify",
      "name": "Classify Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        200,
        300
      ],
      "parameters": {
        "jsCode": "const text=($('Telegram Trigger').first().json.message.text||'').trim();\nconst l=text.toLowerCase();\nconst qw=['?','how ','how much','what','which','when ','show','list','total','average','avg','did i','do i','my biggest','top ','compare','remember','recall','remind','goal','tell me','summary','breakdown','why ','spent on what','where did'];\nconst isQ=qw.some(w=>l.includes(w));\nconst hasNum=/[0-9]/.test(text);\nlet intent = isQ ? 'question' : (hasNum ? 'expense' : 'question');\nreturn [{json:{intent, text}}];"
      }
    },
