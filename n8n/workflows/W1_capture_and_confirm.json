    {
      "id": "build-gemini-body",
      "name": "Build Gemini Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
        300
      ],
      "parameters": {
        "jsCode": "const msg = $('Telegram Trigger').first().json.message.text || '';\nconst prompt = \"You are a personal finance assistant. Extract expense details from the user message and return ONLY a JSON object, no other text, no markdown.\\n\\nCategories (use exactly as written):\\nFood & Dining, Transport, Groceries, Shopping, Entertainment, Health, Utilities, Education, Personal Care, Other\\n\\nReturn JSON with:\\n- amount: number\\n- merchant: cleaned name\\n- category: from list above\\n- need_or_want: Need or Want\\n- confidence: 0.0 to 1.0\\n\\nExamples:\\n\\\"450 swiggy\\\" -> {\\\"amount\\\":450,\\\"merchant\\\":\\\"Swiggy\\\",\\\"category\\\":\\\"Food & Dining\\\",\\\"need_or_want\\\":\\\"Want\\\",\\\"confidence\\\":0.95}\\n\\\"uber 85\\\" -> {\\\"amount\\\":85,\\\"merchant\\\":\\\"Uber\\\",\\\"category\\\":\\\"Transport\\\",\\\"need_or_want\\\":\\\"Need\\\",\\\"confidence\\\":1.0}\\n\\\"Netflix 649\\\" -> {\\\"amount\\\":649,\\\"merchant\\\":\\\"Netflix\\\",\\\"category\\\":\\\"Entertainment\\\",\\\"need_or_want\\\":\\\"Want\\\",\\\"confidence\\\":1.0}\\n\\nMessage: \\\"REPLACE_MESSAGE\\\"\\n\\nReturn only the JSON object.\".replace('REPLACE_MESSAGE', msg);\nreturn [{ json: { body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }) } }];\n"
      }
    },
    {
      "id": "call-gemini",
      "name": "Call Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite:generateContent?key=GEMINI_API_KEY",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.body }}"
      }
    },
    {
      "id": "parse-gemini",
      "name": "Parse Gemini Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        300
      ],
      "parameters": {
        "jsCode": "\nconst raw = $input.first().json;\nconst text = (raw.candidates?.[0]?.content?.parts?.[0]?.text || '').replace(/```json|```/g,'').trim();\nlet parsed;\ntry { parsed = JSON.parse(text); } catch(e) {\n  return [{ json: { parseSuccess: false, error: 'Bad JSON: ' + text.slice(0,100) } }];\n}\nconst amount = parseFloat(parsed.amount);\nif (!amount || isNaN(amount)) {\n  return [{ json: { parseSuccess: false, error: 'No valid amount' } }];\n}\nconst now = new Date();\nconst transaction_id = 'TXN-' + now.getFullYear() +\n  String(now.getMonth()+1).padStart(2,'0') + String(now.getDate()).padStart(2,'0') + '-' +\n  String(now.getHours()).padStart(2,'0') + String(now.getMinutes()).padStart(2,'0') +\n  String(now.getSeconds()).padStart(2,'0');\nconst month_key = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');\nconst confidence = parsed.confidence ?? 0;\nreturn [{ json: {\n  parseSuccess: true,\n  confidence,\n  transaction_id,\n  timestamp: now.toISOString(),\n  raw_message: $('Telegram Trigger').first().json.message.text,\n  amount,\n  merchant_vendor: parsed.merchant || 'Unknown',\n  category: parsed.category || 'Other',\n  subcategory: '',\n  need_or_want: parsed.need_or_want || 'Want',\n  payment_mode: 'Unspecified',\n  confidence_score: confidence,\n  user_corrected: false,\n  month_key,\n  source: 'telegram_text'\n}}];\n"
      }
    },
