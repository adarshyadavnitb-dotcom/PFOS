    {
      "id": "c-add",
      "name": "Build Row",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        250
      ],
      "parameters": {
        "jsCode": "\nconst b = $json.body || {};\nconst istOffset = 5.5*60*60*1000;\nconst now = new Date();\nconst ist = new Date(now.getTime()+istOffset);\nconst pad = n => String(n).padStart(2,'0');\nconst transaction_id = 'TXN-'+ist.getUTCFullYear()+pad(ist.getUTCMonth()+1)+pad(ist.getUTCDate())+'-'+pad(ist.getUTCHours())+pad(ist.getUTCMinutes())+pad(ist.getUTCSeconds());\nconst month_key = ist.getUTCFullYear()+'-'+pad(ist.getUTCMonth()+1);\nreturn [{ json: {\n  transaction_id, timestamp: now.toISOString(),\n  raw_message: ((b.merchant||'')+' '+(b.amount||'')).trim(),\n  amount: parseFloat(b.amount)||0,\n  merchant_vendor: b.merchant || 'Unknown',\n  category: b.category || 'Other',\n  subcategory: '',\n  need_or_want: b.need_or_want || 'Want',\n  payment_mode: 'Dashboard',\n  confidence_score: 1,\n  user_corrected: false,\n  month_key, source: 'dashboard'\n}}];\n"
      }
