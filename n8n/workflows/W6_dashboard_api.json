    {
      "id": "c-asm",
      "name": "Assemble Insight",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        560
      ],
      "parameters": {
        "jsCode": "const raw=$input.first().json;\nlet t=(raw.candidates?.[0]?.content?.parts?.[0]?.text||'').trim();\nif(!t){const a=$('Aggregate Week Insight').first().json; t = a.hasData? ('Weekly spend INR '+a.current_week_total) : 'No expenses logged this week yet.';}\nreturn [{json:{success:true, insight:t}}];"
      }
    },
