    {
      "id": "c-agg",
      "name": "Aggregate Week Insight",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        560
      ],
      "parameters": {
        "jsCode": "\nconst rows = $('R Tx Insight').all().map(i=>i.json);\nconst istOffset=5.5*60*60*1000; const now=new Date(); const msDay=864e5;\nconst istStr=d=>new Date(d.getTime()+istOffset).toISOString().split('T')[0];\nconst cutC=now.getTime()-7*msDay, cutP=now.getTime()-28*msDay;\nlet cur=[],pri=[];\nfor(const r of rows){ if(!r.timestamp) continue; const t=new Date(r.timestamp); if(isNaN(t.getTime()))continue;\n  const a=parseFloat(r.amount)||0; if(t.getTime()>=cutC)cur.push({...r,a}); else if(t.getTime()>=cutP)pri.push({...r,a}); }\nconst week_start=istStr(new Date(now.getTime()-6*msDay)), week_end=istStr(now);\nif(cur.length===0) return [{json:{hasData:false, statsJson:JSON.stringify({week_start,week_end,note:'no spend this week'})}}];\nconst sum=x=>x.reduce((s,r)=>s+r.a,0); const ct=Math.round(sum(cur)); const pavg=Math.round(sum(pri)/3);\nconst cat={}; for(const r of cur){const c=r.category||'Uncategorized'; cat[c]=(cat[c]||0)+r.a;}\nconst breakdown=Object.entries(cat).sort((x,y)=>y[1]-x[1]).map(([category,amount])=>({category,amount:Math.round(amount)}));\nconst need=sum(cur.filter(r=>(r.need_or_want||'').toLowerCase()==='need'));\nconst stats={week_start,week_end,current_week_total:ct,prior_3wk_avg_total:pavg,transaction_count:cur.length,\n  need_pct: ct>0?Math.round(need/ct*100):0, category_breakdown:breakdown};\nreturn [{json:{hasData:true, ...stats, statsJson:JSON.stringify(stats)}}];\n"
      }
    },
    {
      "id": "c-body",
      "name": "Build Insight Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        560
      ],
      "parameters": {
        "jsCode": "const s=$json.statsJson;\nif($json.hasData===false){return [{json:{skip:true, body:JSON.stringify({contents:[{parts:[{text:'noop'}]}]})}}];}\nconst prompt=\"You are a friendly personal finance coach writing a short on-demand weekly insight over Telegram. You are given PRE-COMPUTED stats; do NOT recalculate or invent numbers. Headline on total vs 3-week average, 2 short bullet observations, one encouraging tip. Under 110 words. No markdown (no asterisks). Use bullet char and INR sign. Stats JSON:\\n\"+s+'\\n\\nWrite only the message text.';\nreturn [{json:{skip:false, body:JSON.stringify({contents:[{parts:[{text:prompt}]}],generationConfig:{temperature:0.7}})}}];"
      }
    },
