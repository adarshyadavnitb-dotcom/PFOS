      "parameters": {
        "jsCode": "const q=$('M Webhook').first().json.query||{};\nlet notes=$('M Read').all().map(i=>i.json).filter(r=>r.note).map(r=>({timestamp:r.timestamp,note:r.note,tags:r.tags||''}));\nif(q.q){const kw=String(q.q).toLowerCase(); notes=notes.filter(n=>((n.note||'')+' '+(n.tags||'')).toLowerCase().includes(kw));}\nreturn [{json:{count:notes.length, notes}}];"
