    {
      "id": "qcalc",
      "name": "Q Compute",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        -60
      ],
      "parameters": {
        "jsCode": "\nconst q = $('Q Webhook').first().json.query || {};\nconst rows = $('Q Read').all().map(i=>i.json);\nconst istOffset=5.5*3600*1000;\nconst dstr = r => { if(!r.timestamp) return null; const t=new Date(r.timestamp); if(isNaN(t.getTime())) return null; return new Date(t.getTime()+istOffset).toISOString().slice(0,10); };\nconst amt = r => parseFloat(r.amount)||0;\nlet f = rows.filter(r => r.amount!=null && String(r.amount).trim()!=='');\nif(q.category) f=f.filter(r=>(r.category||'').toLowerCase()===String(q.category).toLowerCase());\nif(q.need_or_want) f=f.filter(r=>(r.need_or_want||'').toLowerCase()===String(q.need_or_want).toLowerCase());\nif(q.start_date) f=f.filter(r=>{const d=dstr(r); return d && d>=q.start_date;});\nif(q.end_date) f=f.filter(r=>{const d=dstr(r); return d && d<=q.end_date;});\nconst total=f.reduce((s,r)=>s+amt(r),0), count=f.length;\nconst result={ filters:q, total_spend:Math.round(total), transaction_count:count, average_per_txn: count?Math.round(total/count):0 };\nconst gb=(q.group_by||'').toLowerCase();\nif(gb==='category'){ const m={}; f.forEach(r=>{const c=r.category||'Other'; m[c]=(m[c]||0)+amt(r);}); result.by_category=Object.entries(m).sort((a,b)=>b[1]-a[1]).map(([k,v])=>({category:k,amount:Math.round(v)})); }\nelse if(gb==='month'){ const m={}; f.forEach(r=>{const k=r.month_key||(dstr(r)||'').slice(0,7); m[k]=(m[k]||0)+amt(r);}); result.by_month=Object.entries(m).sort().map(([k,v])=>({month:k,amount:Math.round(v)})); }\nelse if(gb==='merchant'){ const m={}; f.forEach(r=>{const k=r.merchant_vendor||'Unknown'; m[k]=(m[k]||0)+amt(r);}); result.top_merchants=Object.entries(m).sort((a,b)=>b[1]-a[1]).slice(0,10).map(([k,v])=>({merchant:k,amount:Math.round(v)})); }\nreturn [{ json: result }];\n"
      }
    },
